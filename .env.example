# Copy to .env and edit.  .env is gitignored -- never commit it.
#
# --- Mode A: OAuth passthrough (Claude Pro/Max or OpenCode subscription) ------
# If you log in with 'claude auth login' / 'opencode auth login', leave
# ANTHROPIC_API_KEY empty.  Kiri forwards your OAuth session transparently.
#
ANTHROPIC_BASE_URL=http://localhost:8765
# ANTHROPIC_API_KEY=

# --- Mode B: API key ----------------------------------------------------------
# 1. Put your real Anthropic key in .kiri/upstream.key (never commit that file)
#       echo "sk-ant-YOUR-KEY" > .kiri/upstream.key          # Linux/Mac
#       "sk-ant-YOUR-KEY" | Out-File .kiri\upstream.key      # Windows PS
# 2. Generate a kiri key:  bash scripts/kiri.sh key create
# 3. Paste the kr- key below and uncomment
#
# ANTHROPIC_API_KEY=kr-your-kiri-key-here
