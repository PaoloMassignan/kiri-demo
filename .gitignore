# Local environment — never commit keys
.env

# Kiri runtime state (rebuilt locally)
.kiri/index/
.kiri/keys/
.kiri/logs/
.kiri/models/
.kiri/upstream.key

# Native mode runtime files (generated by start-native.sh / start-native.ps1)
.kiri/config.native.local
.kiri/.mode
.kiri/audit.log

# Python
__pycache__/
*.py[cod]
